PORT=5000

DATABASE_URL=jdbc:postgresql://host:port/database?ssl=true&sslmode=require
DATABASE_USERNAME=your_db_username
DATABASE_PASSWORD=your_db_password

JWT_SECRET=your-jwt-secret-key
